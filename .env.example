# Core DB
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Prisma schema currently reads data_url; keep both to avoid mismatch
data_url=postgres://user:pass@host:5432/dbname

# Auth / app secrets
JWT_SECRET=replace_with_secure_jwt_secret
WORLD_CLIENT_ID=your_world_minikit_client_id
WORLD_CLIENT_SECRET=your_world_minikit_secret
INDEXER_SECRET=replace_with_long_random_secret

# Chain/indexer
P2P_CONTRACT_ADDRESS=0xYourContractAddress
WORLDCHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/v2/your_key

# Pusher (realtime chat)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Public vars
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
NEXT_PUBLIC_API_BASE=/api
